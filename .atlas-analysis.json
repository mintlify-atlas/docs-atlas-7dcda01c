  "keyFeatures": [
    "Fluent API with type-safe enums for invoice creation",
    "XAdES-EPES digital signature with optional TSA timestamping",
    "Support for 29 tax types including VAT, IRPF, IGIC, and surcharges",
    "19 payment methods with split payment support",
    "Validation against official FacturaE 3.2.x XSD schemas",
    "Zero dependencies - only standard PHP extensions required",
    "Corrective invoices with 22 correction reasons",
    "Support for Spanish public administration (FACe) requirements"
  ],
